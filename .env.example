# Template only — copy to .env (gitignored) or export into your shell.
# .env itself is gitignored via the *.env pattern in .gitignore.

# SA password for the SQL Server container (consumed by docker-compose.yml).
MSSQL_SA_PASSWORD=YourStrong!Passw0rd

# Connection string consumed by the .NET app via IConfiguration env-var binding
# (Database__ConnectionString -> DatabaseSettings:ConnectionString).
# `dotnet run` does NOT auto-load .env files — export this into your shell:
#   PowerShell:  $env:Database__ConnectionString="..."
#   cmd:         set Database__ConnectionString=...
#   bash:        export Database__ConnectionString="..."
Database__ConnectionString=Server=localhost,1433;Database=HealthCasePlatform;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True;MultipleActiveResultSets=true
