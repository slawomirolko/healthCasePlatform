{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Audit": {
    "Provider": "SqlServer"
  },
  "MongoAudit": {
    "Database": "HealthCasePlatform",
    "CollectionName": "auditEntries"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "CaseSubmittedQueue": "case-submitted",
    "DispatcherIntervalSeconds": 2
  }
}
